APP_NAME="SARS-CoV-2 Analysis API"
API_PREFIX="/api/v1"
MAX_UPLOAD_FILES=25
MAX_UPLOAD_BYTES=10000000
MAX_FASTA_RECORDS_PER_REQUEST=250

# Preferred production/local Postgres connection
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/sarscov2"

# Optional discrete Postgres settings if DATABASE_URL is not used
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="sarscov2"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"

# Keep true for local development without Postgres
USE_SQLITE_FALLBACK=true
SQLITE_FALLBACK_URL="sqlite:///./sarscov2.db"

REFERENCE_ACCESSION="NC_045512.2"

